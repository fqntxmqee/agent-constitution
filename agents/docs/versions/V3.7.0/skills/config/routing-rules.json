{
  "version": "1.0",
  "defaultRoute": "standard",
  "rules": [
    {
      "id": "R-001",
      "priority": 100,
      "conditions": [
        { "field": "skill01.intent", "operator": "equals", "value": "development" },
        { "field": "skill03.complexity", "operator": "in", "value": ["high", "medium"] }
      ],
      "then": { "routeTo": "requirement-understanding" }
    },
    {
      "id": "R-002",
      "priority": 95,
      "conditions": [
        { "field": "skill01.intent", "operator": "equals", "value": "development" }
      ],
      "then": { "routeTo": "requirement-understanding" }
    },
    {
      "id": "R-003",
      "priority": 90,
      "conditions": [
        { "field": "skill01.intent", "operator": "equals", "value": "content" },
        { "field": "skill03.estimatedSteps", "operator": "lessThan", "value": 3 }
      ],
      "then": { "routeTo": "requirement-resolution" }
    },
    {
      "id": "R-004",
      "priority": 85,
      "conditions": [
        { "field": "skill01.intent", "operator": "in", "value": ["content", "skill", "operation"] }
      ],
      "then": { "routeTo": "fast" }
    },
    {
      "id": "R-005",
      "priority": 80,
      "conditions": [
        { "field": "skill03.complexity", "operator": "equals", "value": "low" },
        { "field": "skill03.estimatedSteps", "operator": "lessThan", "value": 5 }
      ],
      "then": { "routeTo": "fast" }
    }
  ]
}
