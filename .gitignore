# 默认忽略所有文件
*

# 不忽略 agents 及其子目录（否则下文的 !agents/docs/* 无法生效）
!agents/
!agents/docs/
!agents/docs/specs/
!agents/docs/specs/constitution/
!agents/docs/specs/process/
!agents/docs/specs/skills/
!agents/docs/specs/meta/
!agents/docs/versions/

# 不忽略宪法文件
!agents/constitution/*/IDENTITY.md
!agents/constitution/*/AGENTS.md
!agents/constitution/*/SOUL.md
!agents/constitution/*/MEMORY.md
!agents/constitution/*/TOOLS.md
!agents/constitution/*/HEARTBEAT.md

# 不忽略配置状态文件
!agents/constitution/CONFIG_STATUS.md
# 不忽略团队角色文件
!agents/constitution/TEAM_ROLES.md
# 不忽略配置状态文件
!agents/constitution/CONFIG_STATUS.md

# 不忽略宪法规范相关文档文件
!agents/docs/*
!agents/docs/specs/*
!agents/docs/specs/constitution/*
!agents/docs/specs/constitution/backup/*
!agents/docs/specs/constitution/upgrade/*
!agents/docs/specs/constitution/change-classification/*
!agents/docs/specs/constitution/directory-standard/*
!agents/docs/specs/constitution/upgrade/*
!agents/docs/specs/constitution/change-classification/*
!agents/docs/specs/constitution/directory-standard/*

# 不忽略版本文件
!agents/docs/versions/*
!agents/docs/versions/V*/
!agents/docs/versions/V*/agents/*
!agents/docs/versions/V*/constitution/*
!agents/docs/versions/V*/skills/*

# 不忽略技能文件
!agents/skills/*
!agents/skills/SKILL_*.md