# 默认忽略所有文件
*

# ---------- 仓库根 ----------
!.gitignore
!AGENTS.md

# ---------- agents（宪法与智能体） ----------
!agents/
!agents/docs/
!agents/docs/specs/
!agents/docs/specs/constitution/
!agents/docs/specs/process/
!agents/docs/specs/skills/
!agents/docs/specs/meta/
!agents/docs/versions/

# 宪法智能体配置（8 个子目录内指定文件）
!agents/constitution/
!agents/constitution/*/
!agents/constitution/*/AGENTS.md
!agents/constitution/*/IDENTITY.md
!agents/constitution/*/SOUL.md
!agents/constitution/*/TOOLS.md
!agents/constitution/CONFIG_STATUS.md
!agents/constitution/TEAM_ROLES.md

# agents/docs/specs 下规范文档（constitution 子目录完整）
!agents/docs/specs/README.md
!agents/docs/specs/constitution/
!agents/docs/specs/constitution/*
!agents/docs/specs/constitution/*/*
!agents/docs/specs/constitution/*/*/*
!agents/docs/specs/process/
!agents/docs/specs/process/*
!agents/docs/specs/skills/
!agents/docs/specs/skills/*
!agents/docs/specs/meta/
!agents/docs/specs/meta/*

# agents/docs 其他（决策/讨论/提案/模板）
!agents/docs/decisions/
!agents/docs/decisions/*
!agents/docs/discussions/
!agents/docs/discussions/*
!agents/docs/proposals/
!agents/docs/proposals/*
!agents/docs/proposals/*/*
!agents/docs/templates/
!agents/docs/templates/*

# 版本备份（先版本后类型：V{version}/agents|constitution|skills）
!agents/docs/versions/README.md
!agents/docs/versions/latest
!agents/docs/versions/V*/
!agents/docs/versions/V*/*
!agents/docs/versions/V*/*/
!agents/docs/versions/V*/constitution/
!agents/docs/versions/V*/constitution/*
!agents/docs/versions/V*/constitution/*/*
!agents/docs/versions/V*/agents/
!agents/docs/versions/V*/agents/*
!agents/docs/versions/V*/agents/*/*
!agents/docs/versions/V*/skills/
!agents/docs/versions/V*/skills/*
!agents/docs/versions/V*/skills/*/*

# agents/skills
!agents/skills/
!agents/skills/*
!agents/skills/*/*
!agents/skills/*/*/*
